# ─── Backend (Axum server & worker) ───
# For local dev (without Docker):
#   MONGO_URI=mongodb://127.0.0.1:27017
#   BIND_ADDR=127.0.0.1:8080
# Docker Compose overrides MONGO_URI and BIND_ADDR automatically.
MONGO_USER=admin
MONGO_PASS=change-me-in-production
MONGO_DB=fantasy500
JWT_SECRET=change-me-in-production
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS
RPC_URL=https://api.devnet.solana.com

# Gemini API key for AI-generated commissioner reports (optional)
GEMINI_API_KEY=

# ─── Frontend (Vite injects VITE_ vars at build time) ───
VITE_SOLANA_RPC=
VITE_API_BASE=
VITE_WS_BASE=

# ─── Docker Compose ───
# PORT controls which host port the frontend is exposed on (default: 3000)
PORT=3000
# RUST_LOG controls log verbosity for server & worker (default: info)
RUST_LOG=info
